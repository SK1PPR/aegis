        "update_package": {
          "name": "powertrain_ecu_v5.1.3",
          "size_mb": 8,
          "checksum": "sha384:mno345...",
          "signature": "ECDSA_P384:pqr678...",
          "compression": "lzma",
          "encryption": "AES256_GCM"
